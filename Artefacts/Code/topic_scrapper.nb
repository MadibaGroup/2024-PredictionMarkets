 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fetchPage", "[", 
     RowBox[{"offset_", ",", 
      RowBox[{"limit_", ":", "500"}]}], "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"url", ",", "raw"}], "}"}], ",", 
      RowBox[{
       RowBox[{"url", "=", 
        RowBox[{"URLBuild", "[", 
         RowBox[{"base", ",", 
          RowBox[{"{", 
           RowBox[{
            RowBox[{"\"\<limit\>\"", "->", 
             RowBox[{"ToString", "[", "limit", "]"}]}], ",", 
            RowBox[{"\"\<offset\>\"", "->", 
             RowBox[{"ToString", "[", "offset", "]"}]}]}], "}"}]}], "]"}]}], ";",
