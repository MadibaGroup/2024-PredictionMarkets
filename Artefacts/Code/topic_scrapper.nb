 RowBox[{
  RowBox[{
   RowBox[{"isChainlinkUpDown", "[", "row_", "]"}], ":=", 
   RowBox[{
    RowBox[{"StringContainsQ", "[", 
     RowBox[{
      RowBox[{"ToLowerCase", "[", 
       RowBox[{"row", "[", 
