       RowBox[{"raw", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"url", ",", "\"\<RawJSON\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", "raw"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"fetchID", "[", "id_", "]"}], ":=", 
    RowBox[{"Module", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"url", ",", "raw"}], "}"}], ",", 
      RowBox[{
       RowBox[{"url", "=", 
        RowBox[{"URLBuild", "[", 
         RowBox[{"{", 
          RowBox[{"base", ",", 
           RowBox[{"ToString", "[", "id", "]"}]}], "}"}], "]"}]}], ";", 
       "\[IndentingNewLine]", 
       RowBox[{"raw", "=", 
        RowBox[{"Import", "[", 
         RowBox[{"url", ",", "\"\<RawJSON\>\""}], "]"}]}], ";", 
       "\[IndentingNewLine]", "raw"}]}], "]"}]}], ";"}], 
  "\[IndentingNewLine]"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{"shrinkPage", "[", 
    RowBox[{"{", "}"}], "]"}], ":=", 
   RowBox[{"{", "}"}]}], ";"}], "\n", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"shrinkPage", "[", "$Failed", "]"}], ":=", "$Failed"}], ";"}], 
  "\n"}], "\[IndentingNewLine]", 
 RowBox[{
  RowBox[{
   RowBox[{
    RowBox[{"shrinkPage", "[", "page_", "]"}], ":=", 
    RowBox[{
     RowBox[{
      RowBox[{"{", "\[IndentingNewLine]", 
       RowBox[{
        RowBox[{"Lookup", "[", 
         RowBox[{"#", ",", "\"\<id\>\"", ",", "\"\<\>\""}], "]"}], ",", 
